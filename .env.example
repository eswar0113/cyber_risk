# Email configuration
GMAIL_SENDER="your_email@gmail.com"
GMAIL_PASSWORD="your_app_password"

# VirusTotal API Key (Get yours from https://www.virustotal.com/)
VT_API_KEY="yourVTAPIhere"

# PostgreSQL credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cyber_risk_db
DB_USER=postgres
DB_PASSWORD=your_db_password

# Path to nmap binary (only needed if nmap is not on your system PATH)
# After installing Nmap from https://nmap.org/download, set this to:
# NMAP_PATH=C:\Program Files (x86)\Nmap\nmap.exe
NMAP_PATH=nmap
